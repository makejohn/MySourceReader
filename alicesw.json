{
  "爱丽丝书屋": {
    "sourceName": "爱丽丝书屋",
    "sourceUrl": "https://alicesw.com",
    "sourceType": "text",
    "enable": 1,
    "weight": "9999",
    "httpHeaders": {
      "User-Agent": "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15"
    },
    "searchBook": {
      "actionID": "searchBook",
      "parserID": "DOM",
      "host": "https://alicesw.com",
      "validConfig": "",
      "responseFormatType": "html",
      "requestInfo": "@js:\nvar url = config.host + '/search.html?q=' + encodeURIComponent(params.keyWord) + '&f=_all';\nreturn {'url': url, 'POST': false, 'httpHeaders': config.httpHeaders};",
      "httpHeaders": {
        "User-Agent": "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15"
      },
      "list": "//div[contains(@class,'list-group-item')]",
      "bookName": "//h5/a",
      "author": "//p[contains(@class,'text-muted')]/a[contains(@href,'f=author')]",
      "detailUrl": "//h5/a/@href",
      "cover": "",
      "desc": "//p[contains(@class,'content-txt')]",
      "status": "//h5/small"
    },
    "bookDetail": {
      "actionID": "bookDetail",
      "parserID": "DOM",
      "host": "https://alicesw.com",
      "validConfig": "",
      "responseFormatType": "html",
      "requestInfo": "@js:\nreturn {'url': result, 'POST': false, 'httpHeaders': config.httpHeaders};",
      "httpHeaders": {
        "User-Agent": "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15"
      },
      "bookName": "//div[contains(@class,'novel_title')]",
      "author": "//div[contains(@class,'novel_info')]//p/a[contains(@href,'f=author')]",
      "cover": "//div[contains(@class,'box_intro')]//div[contains(@class,'pic')]//img/@src",
      "desc": "//div[contains(@class,'jianjie')]/p",
      "cat": "//div[contains(@class,'novel_info')]//p/a[contains(@href,'/lists/')]",
      "status": "//div[contains(@class,'novel_info')]//p[contains(text(),'状')]",
      "wordCount": "//div[contains(@class,'novel_info')]//p[contains(text(),'字')]",
      "lastChapterTitle": "//div[contains(@class,'novel_info')]//p[contains(text(),'最')]/a"
    },
    "chapterList": {
      "actionID": "chapterList",
      "parserID": "DOM",
      "host": "https://alicesw.com",
      "validConfig": "",
      "responseFormatType": "html",
      "requestInfo": "@js:\nvar u = String(result);\nvar m = u.match(/novel\\/(\\d+)\\.html/);\nreturn {'url': config.host + '/other/chapters/id/' + m[1] + '.html', 'POST': false, 'httpHeaders': config.httpHeaders};",
      "httpHeaders": {
        "User-Agent": "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15"
      },
      "list": "//ul[contains(@class,'mulu_list')]/li/a",
      "title": "//text()",
      "url": "//@href"
    },
    "chapterContent": {
      "actionID": "chapterContent",
      "parserID": "DOM",
      "host": "https://alicesw.com",
      "validConfig": "",
      "responseFormatType": "html",
      "content": "//div[contains(@class,'read-content')]"
    }
  }
}
